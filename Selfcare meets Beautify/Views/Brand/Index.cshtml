@model IList<Brand>

<div class="container">


    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row pt-4 pb-3">
        <div class="col-10 text-center fw-bold">
            <h2 >Brands</h2>
        </div>
        <div class="col-2 text-end">
            <a asp-controller="Brand" asp-action="Create" class="btn btn-secondary">
                <i class="bi bi-patch-plus"></i> Create New
            </a>
        </div>
    </div>

    <div class="row justify-content-center text-center">
        @if (Model != null && Model.Count > 0)
        {
            @foreach (var brand in Model)
            {
                <div class="col-6 col-sm-4 col-md-3 col-lg-2 mb-2">
                    <div class="card text-white rounded-0" >
                        
                        <a asp-action="Details"
                           asp-route-id="@brand.Id"
                           asp-controller="Brand"
                           class="card-body p-4 text-center border-0 text-white"
                           style="text-decoration:none; display: block;background-color:deeppink">

                            <h5 class="card-title mb-0"
                                style="font-weight:bolder; font-size:large;">
                                @brand.Name
                            </h5>

                            <!-- Product Count Badge -->
                            <div class="mt-2">
                                <span class="badge bg-light text-dark">
                                    @brand.Products.Count product@(brand.Products.Count != 1 ? "s" : "")
                                </span>
                            </div>
                        </a>
                    </div>
                    <div class="card-footer p-0">
                        <div class="row g-0">
                            <div class="col-6">
                                <a asp-action="Edit" asp-route-id="@brand.Id"
                                   class="btn btn-secondary w-100 btn-lg rounded-0">Edit</a>
                            </div>
                            <div class="col-6">
                                <a asp-action="Delete" asp-route-id="@brand.Id"
                                   class="btn btn-dark w-100 btn-lg rounded-0">Delete</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 mt-5">
                <h4 class="text-secondary">No brands found. Click 'Create New' to add the first brand!</h4>
            </div>
        }
    </div>
</div>